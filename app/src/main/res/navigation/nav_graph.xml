<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Màn hình Login -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.greenhousesystem.ui.auth.LoginFragment"
        android:label="Đăng nhập"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />

        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Màn hình Register -->
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.greenhousesystem.ui.auth.RegisterFragment"
        android:label="Đăng ký"
        tools:layout="@layout/fragment_register">

        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.greenhousesystem.ui.home.HomeFragment"
        android:label="" />

    <fragment
        android:id="@+id/chartFragment"
        android:name="com.example.greenhousesystem.ui.chart.ChartFragment"
        android:label="Biểu đồ" />

    <fragment
        android:id="@+id/controlFragment"
        android:name="com.example.greenhousesystem.ui.control.ControlFragment"
        android:label="Điều khiển" />

    <fragment
        android:id="@+id/notificationFragment"
        android:name="com.example.greenhousesystem.ui.notification.NotificationFragment"
        android:label="Thông báo" />


</navigation>