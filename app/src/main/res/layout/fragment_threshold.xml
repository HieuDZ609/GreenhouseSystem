<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sunset_gradient"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBack"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_marginEnd="12dp" android:clickable="true" android:focusable="true"
                app:cardBackgroundColor="#66FFFFFF" app:cardCornerRadius="12dp"
                app:cardElevation="2dp" app:strokeColor="#CCFFFFFF" app:strokeWidth="1dp">
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:layout_gravity="center" android:src="@drawable/ic_back"
                    app:tint="#636E72"/>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Cấu hình" android:textSize="11sp" android:textColor="#A29BFE"
                    android:fontFamily="@font/montserrat_medium" android:letterSpacing="0.1"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Ngưỡng cảnh báo" android:textSize="22sp" android:textStyle="bold"
                    android:textColor="#2D3436" android:fontFamily="@font/montserrat_bold"/>
            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" app:cardBackgroundColor="#80FFFFFF"
            app:cardCornerRadius="20dp" app:cardElevation="2dp"
            app:strokeColor="#CCFFFFFF" app:strokeWidth="1.5dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_plant_placeholder" android:layout_marginEnd="10dp"
                    app:tint="#A29BFE"/>
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="Cây đang trồng:"
                    android:textSize="13sp" android:textColor="#636E72"
                    android:fontFamily="@font/montserrat_medium"/>
                <TextView android:id="@+id/tvCurrentPlant"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="#A29BFE" android:fontFamily="@font/montserrat_bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" app:cardBackgroundColor="#80FFFFFF"
            app:cardCornerRadius="24dp" app:cardElevation="4dp"
            app:strokeColor="#CCFFFFFF" app:strokeWidth="1.5dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="24dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="🌡️ Ngưỡng nhiệt độ"
                        android:textSize="15sp" android:textStyle="bold"
                        android:textColor="#2D3436" android:fontFamily="@font/montserrat_bold"/>
                    <TextView android:id="@+id/tvTempWarning"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚠️ Min ≥ Max" android:textSize="11sp"
                        android:textColor="#FF7675" android:fontFamily="@font/montserrat_bold"
                        android:visibility="gone"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tối thiểu" android:textSize="10sp"
                            android:textColor="#636E72" android:fontFamily="@font/montserrat_medium"/>
                        <TextView android:id="@+id/tvTempMinValue"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="15°C" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="#FAB1A0" android:fontFamily="@font/montserrat_bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:gravity="end">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tối đa" android:textSize="10sp"
                            android:textColor="#636E72" android:fontFamily="@font/montserrat_medium"/>
                        <TextView android:id="@+id/tvTempMaxValue"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="35°C" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="#FF7675" android:fontFamily="@font/montserrat_bold"/>
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.slider.RangeSlider
                    android:id="@+id/sliderTempRange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:valueFrom="0"
                    android:valueTo="50"
                    android:stepSize="1"
                    app:thumbColor="#FF7675"
                    app:trackColorActive="#FAB1A0"
                    app:trackColorInactive="#33FAB1A0"
                    app:thumbRadius="12dp"
                    app:trackHeight="5dp"
                    app:haloColor="#33FF7675"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Vùng an toàn:" android:textSize="10sp"
                    android:textColor="#636E72" android:fontFamily="@font/montserrat_medium"
                    android:layout_marginBottom="6dp"/>

                <FrameLayout android:id="@+id/viewTempRangeTrack"
                    android:layout_width="match_parent" android:layout_height="12dp"
                    android:background="@drawable/bg_glass_tube_track" android:layout_marginBottom="4dp">
                    <View android:id="@+id/viewTempRangeBar"
                        android:layout_width="0dp" android:layout_height="match_parent"
                        android:background="@drawable/bg_liquid_pink"/>
                </FrameLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="0°C"
                        android:textSize="9sp" android:textColor="#B2BEC3"
                        android:fontFamily="@font/montserrat_medium"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="50°C" android:textSize="9sp" android:textColor="#B2BEC3"
                        android:fontFamily="@font/montserrat_medium"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="24dp" app:cardBackgroundColor="#80FFFFFF"
            app:cardCornerRadius="24dp" app:cardElevation="4dp"
            app:strokeColor="#CCFFFFFF" app:strokeWidth="1.5dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="24dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="💧 Ngưỡng độ ẩm"
                        android:textSize="15sp" android:textStyle="bold"
                        android:textColor="#2D3436" android:fontFamily="@font/montserrat_bold"/>
                    <TextView android:id="@+id/tvHumidWarning"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚠️ Min ≥ Max" android:textSize="11sp"
                        android:textColor="#FF7675" android:fontFamily="@font/montserrat_bold"
                        android:visibility="gone"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tối thiểu" android:textSize="10sp"
                            android:textColor="#636E72" android:fontFamily="@font/montserrat_medium"/>
                        <TextView android:id="@+id/tvHumidMinValue"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="40%" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="#A29BFE" android:fontFamily="@font/montserrat_bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:gravity="end">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tối đa" android:textSize="10sp"
                            android:textColor="#636E72" android:fontFamily="@font/montserrat_medium"/>
                        <TextView android:id="@+id/tvHumidMaxValue"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="90%" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="#74B9FF" android:fontFamily="@font/montserrat_bold"/>
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.slider.RangeSlider
                    android:id="@+id/sliderHumidRange"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:valueFrom="0" android:valueTo="100" android:stepSize="1"
                    app:thumbColor="#74B9FF" app:trackColorActive="#A29BFE"
                    app:trackColorInactive="#33A29BFE" app:thumbRadius="12dp"
                    app:trackHeight="5dp" app:haloColor="#3374B9FF"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Vùng an toàn:" android:textSize="10sp"
                    android:textColor="#636E72" android:fontFamily="@font/montserrat_medium"
                    android:layout_marginBottom="6dp"/>

                <FrameLayout android:id="@+id/viewHumidRangeTrack"
                    android:layout_width="match_parent" android:layout_height="12dp"
                    android:background="@drawable/bg_glass_tube_track" android:layout_marginBottom="4dp">
                    <View android:id="@+id/viewHumidRangeBar"
                        android:layout_width="0dp" android:layout_height="match_parent"
                        android:background="@drawable/bg_liquid_blue"/>
                </FrameLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="0%"
                        android:textSize="9sp" android:textColor="#B2BEC3"
                        android:fontFamily="@font/montserrat_medium"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="100%" android:textSize="9sp" android:textColor="#B2BEC3"
                        android:fontFamily="@font/montserrat_medium"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                android:layout_width="0dp" android:layout_height="60dp"
                android:layout_weight="1" android:layout_marginEnd="10dp"
                android:text="Đặt lại" android:textColor="#A29BFE"
                android:fontFamily="@font/montserrat_bold"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="#A29BFE" app:strokeWidth="1.5dp" app:cornerRadius="20dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp" android:layout_height="60dp"
                android:layout_weight="2"
                android:text="💾  Lưu ngưỡng"
                android:textSize="15sp" android:textColor="#FFFFFF"
                android:fontFamily="@font/montserrat_bold"
                android:background="@drawable/bg_liquid_button_sunset"
                app:cornerRadius="30dp"
                app:rippleColor="#4DFFFFFF"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>