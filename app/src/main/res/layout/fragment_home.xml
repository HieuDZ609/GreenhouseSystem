<?xml version="1.0" encoding="utf-8"?>
<!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  fragment_home_new.xml — "Smart Oasis" Dashboard Home       ║
    ║  Theme: Eco-Digital Dark Mode with Glassmorphism            ║
    ║  Bố cục: Telemetry cards dạng liquid gauge, LED status,     ║
    ║  Device status với pulse animation, alert banner frosted.   ║
    ╚══════════════════════════════════════════════════════════════╝
-->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--
        ScrollView bao toàn bộ nội dung.
        Background dùng màu deep forest gradient thay vì flat color.
        Được set programmatically trong HomeFragment.kt
    -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_eco_dark"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="32dp"
            android:paddingHorizontal="16dp">

            <!-- ══════════════════════════════════════════════
                 SECTION 1: GREETING HEADER
                 Hiện thị lời chào + tên user, slide-in từ trên
                 ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp"
                android:alpha="0"
                android:translationY="-20dp">
                <!-- Alpha=0 và translationY ban đầu để thực hiện
                     staggered entrance animation trong Fragment -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xin chào, 🌿"
                        android:textSize="13sp"
                        android:textColor="#9DC8A6"
                        android:fontFamily="@font/montserrat_medium"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart Oasis"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#E8F5E9"
                        android:fontFamily="@font/montserrat_bold"/>

                </LinearLayout>

                <!--
                    Nút thông báo với badge số chưa đọc.
                    Sử dụng FrameLayout để overlay badge lên icon.
                -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp">

                    <ImageView
                        android:id="@+id/btnNotification"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_glass_button"
                        android:padding="12dp"
                        android:src="@drawable/ic_bell"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#84CC16"/>

                    <!-- Badge số thông báo chưa đọc -->
                    <TextView
                        android:id="@+id/tvNotifBadge"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="top|end"
                        android:gravity="center"
                        android:text="3"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_badge_red"
                        android:visibility="gone"/>

                </FrameLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════════════
                 SECTION 2: DEVICE STATUS CARD (Glassmorphic)
                 Pulse animation cho chấm xanh Online/Offline
                 Stagger delay: 100ms
                 ══════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDeviceStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                android:translationY="40dp"
                app:cardBackgroundColor="#1A2D1E"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#2D4A31"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <!-- Pulse container: chấm xanh + vòng sóng lan -->
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="14dp">

                        <!--
                            Vòng pulse ngoài cùng (scale 0→1.8 + alpha 1→0 lặp lại)
                            Được animate bằng ObjectAnimator trong Fragment
                        -->
                        <View
                            android:id="@+id/viewPulseOuter"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_pulse_outer"
                            android:alpha="0"/>

                        <!-- Vòng pulse giữa (delay 300ms) -->
                        <View
                            android:id="@+id/viewPulseMiddle"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_pulse_middle"
                            android:alpha="0"/>

                        <!-- Chấm trạng thái (luôn hiển thị) -->
                        <View
                            android:id="@+id/viewStatusDot"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:background="@drawable/circle_gray"/>

                    </FrameLayout>

                    <!-- Thông tin trạng thái thiết bị -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thiết bị ESP32"
                            android:textSize="11sp"
                            android:textColor="#7FA884"
                            android:fontFamily="@font/montserrat_medium"
                            android:letterSpacing="0.08"/>

                        <TextView
                            android:id="@+id/tvDeviceStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Offline"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#9E9E9E"
                            android:fontFamily="@font/montserrat_bold"/>

                        <TextView
                            android:id="@+id/tvLastSeen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:textSize="11sp"
                            android:textColor="#4A6A4E"/>

                    </LinearLayout>

                    <!-- Divider dọc -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#2D4A31"
                        android:layout_marginHorizontal="16dp"/>

                    <!-- Cây đang trồng -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đang trồng"
                            android:textSize="11sp"
                            android:textColor="#7FA884"
                            android:fontFamily="@font/montserrat_medium"
                            android:letterSpacing="0.08"/>

                        <TextView
                            android:id="@+id/tvPlantName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Chưa chọn"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#84CC16"
                            android:fontFamily="@font/montserrat_bold"/>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════
                 SECTION 3: ALERT BANNER (Frosted Glass overlay)
                 Xuất hiện khi có cảnh báo, slide down + fade in
                 Stagger delay: 150ms
                 ══════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:translationY="-16dp"
                app:cardBackgroundColor="#3D1515"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#8B2020"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!--
                        Icon cảnh báo dạng vòng tròn
                        Sẽ animate shake (rotation ±5dp) khi hiện
                    -->
                    <FrameLayout
                        android:id="@+id/iconAlertContainer"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_alert_icon"
                        android:layout_marginEnd="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_warning"
                            app:tint="#FF6B6B"/>

                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvAlertMessage"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textColor="#FF8A8A"
                        android:textSize="13sp"
                        android:fontFamily="@font/montserrat_medium"
                        android:lineSpacingMultiplier="1.3"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════
                 SECTION 4: LIQUID GAUGE CARDS (Temp + Humidity)
                 Đây là trung tâm của dashboard.
                 Mỗi card là một "liquid gauge" — hình tròn với
                 mực nước dâng lên theo giá trị cảm biến.
                 Custom View sẽ được vẽ bằng Canvas trong Kotlin.
                 Stagger delay: 200ms và 300ms
                 ══════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- ── CARD NHIỆT ĐỘ ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTemperature"
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:alpha="0"
                    android:translationY="40dp"
                    app:cardBackgroundColor="#0F1E12"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E3B22"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <!-- Label tiêu đề -->
                        <TextView
                            android:id="@+id/labelTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhiệt độ"
                            android:textSize="11sp"
                            android:textColor="#4A8C52"
                            android:fontFamily="@font/montserrat_medium"
                            android:letterSpacing="0.1"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <!-- Lottie icon nhiệt kế -->
                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/lottieTempIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            app:lottie_autoPlay="true"
                            app:lottie_loop="true"
                            app:lottie_rawRes="@raw/temperature"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <!--
                            LiquidGaugeView — Custom View vẽ bằng Canvas.
                            Hiển thị mực nước dâng theo % giá trị.
                            File: LiquidGaugeView.kt (xem code Kotlin bên dưới)
                        -->
                        <com.example.greenhousesystem.ui.widget.LiquidGaugeView
                            android:id="@+id/gaugeTemperature"
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            app:gaugeColor="#E53935"
                            app:gaugeWaveColor="#B71C1C"
                            app:gaugeMin="0"
                            app:gaugeMax="50"
                            app:layout_constraintTop_toBottomOf="@id/labelTemp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toTopOf="@id/tvTemperature"/>

                        <!-- Giá trị số lớn -->
                        <TextView
                            android:id="@+id/tvTemperature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--°C"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#ECEFF1"
                            android:fontFamily="@font/montserrat_bold"
                            app:layout_constraintBottom_toTopOf="@id/tvTempStatus"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <!-- Trạng thái (Bình thường / Quá cao / Quá thấp) -->
                        <TextView
                            android:id="@+id/tvTempStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="10sp"
                            android:textColor="#4A8C52"
                            android:fontFamily="@font/montserrat_medium"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/bg_status_badge"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── CARD ĐỘ ẨM ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHumidity"
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:alpha="0"
                    android:translationY="40dp"
                    app:cardBackgroundColor="#0D1A2A"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1A3550"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/labelHumid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Độ ẩm"
                            android:textSize="11sp"
                            android:textColor="#4A70A8"
                            android:fontFamily="@font/montserrat_medium"
                            android:letterSpacing="0.1"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/lottieHumidityIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            app:lottie_autoPlay="true"
                            app:lottie_loop="true"
                            app:lottie_rawRes="@raw/water_drop"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <com.example.greenhousesystem.ui.widget.LiquidGaugeView
                            android:id="@+id/gaugeHumidity"
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            app:gaugeColor="#1E88E5"
                            app:gaugeWaveColor="#0D47A1"
                            app:gaugeMin="0"
                            app:gaugeMax="100"
                            app:layout_constraintTop_toBottomOf="@id/labelHumid"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toTopOf="@id/tvHumidity"/>

                        <TextView
                            android:id="@+id/tvHumidity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--%"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#ECEFF1"
                            android:fontFamily="@font/montserrat_bold"
                            app:layout_constraintBottom_toTopOf="@id/tvHumidityStatus"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/tvHumidityStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="10sp"
                            android:textColor="#4A70A8"
                            android:fontFamily="@font/montserrat_medium"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/bg_status_badge_blue"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══════════════════════════════════════════════
                 SECTION 5: LED STATUS CARD (Glassmorphic)
                 Hiển thị trạng thái LED + toggle switch.
                 Nền card thay đổi màu mờ theo màu LED hiện tại.
                 Stagger delay: 400ms
                 ══════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                android:translationY="40dp"
                app:cardBackgroundColor="#161A10"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#2D3520"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <!--
                        Preview màu LED — hình cầu phát sáng.
                        Background color được set dynamically theo R/G/B.
                        Outer glow được tạo bằng stroke + alpha.
                    -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/viewLedGlow"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="3dp"
                        app:strokeColor="#33FFFFFF">

                        <!-- Inner color orb -->
                        <View
                            android:id="@+id/viewLedColor"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#222222"/>

                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đèn LED RGB"
                            android:textSize="11sp"
                            android:textColor="#7A8C60"
                            android:fontFamily="@font/montserrat_medium"
                            android:letterSpacing="0.08"/>

                        <TextView
                            android:id="@+id/tvLedMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="-- Chưa có dữ liệu"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#C8E6C9"
                            android:fontFamily="@font/montserrat_bold"/>

                        <!-- RGB values dạng neon text -->
                        <TextView
                            android:id="@+id/tvLedRgb"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="R:0 G:0 B:0"
                            android:textSize="11sp"
                            android:textColor="#4A6A3A"
                            android:fontFamily="@font/montserrat_medium"/>

                    </LinearLayout>

                    <!--
                        SwitchMaterial với custom thumb và track.
                        Thumbcolor = lime green khi on, gray khi off.
                    -->
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchLed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/switch_thumb_color"
                        android:trackTint="@color/switch_track_color"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════
                 SECTION 6: LAST UPDATE TIMESTAMP
                 Stagger delay: 500ms
                 ══════════════════════════════════════════════ -->
            <TextView
                android:id="@+id/tvLastUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cập nhật lần cuối: --"
                android:textSize="11sp"
                android:textColor="#3A5C3E"
                android:gravity="center"
                android:alpha="0"
                android:fontFamily="@font/montserrat_medium"
                android:letterSpacing="0.05"/>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>