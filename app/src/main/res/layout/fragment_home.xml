<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_home_light.xml — Dashboard Light Mode "Soft Sunset"
    ══════════════════════════════════════════════════════════════
    Phân cấp thị giác (Visual Hierarchy):
    ┌─────────────────────────────────────────────────────┐
    │ LAYER 3 (trên cùng):  Nội dung (text, icon, số)    │
    │ LAYER 2 (giữa):       Glass Cards (trắng 40-60%)   │
    │ LAYER 1 (dưới cùng):  Sunset Gradient Background   │
    └─────────────────────────────────────────────────────┘
    Gradient nền xuyên qua lớp kính → hiệu ứng depth tự nhiên.
-->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_sunset_gradient"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- ══ HEADER: Greeting + Theme Toggle ══ -->
            <LinearLayout
                android:id="@+id/layoutHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp"
                android:alpha="0"
                android:translationY="-16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xin chào 🌸"
                        android:textSize="13sp"
                        android:textColor="#636E72"
                        android:fontFamily="@font/montserrat_medium"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart Oasis"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#2D3436"
                        android:fontFamily="@font/montserrat_bold"/>

                </LinearLayout>

                <!--
                    🌙/☀️ Nút Toggle Dark/Light Mode
                    Capsule shape với glass background.
                    Click gọi ThemeToggleHelper.toggleTheme()
                    Icon đổi theo mode hiện tại.
                -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnThemeToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#80FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#CCFFFFFF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingHorizontal="14dp">

                        <!-- Icon ☀️ hoặc 🌙 — set programmatically -->
                        <ImageView
                            android:id="@+id/ivThemeIcon"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_moon"
                            android:layout_marginEnd="6dp"
                            app:tint="#A29BFE"/>

                        <TextView
                            android:id="@+id/tvThemeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dark"
                            android:textSize="12sp"
                            android:textColor="#A29BFE"
                            android:fontFamily="@font/montserrat_bold"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Notification bell -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnNotification"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#80FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#CCFFFFFF"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_bell"
                        app:tint="#A29BFE"/>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══ DEVICE STATUS GLASS CARD ══ -->
            <!--
                Card kính DÀY (#99FFFFFF) vì đây là thông tin quan trọng.
                Online dot + pulse animation.
            -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDeviceStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                android:translationY="30dp"
                app:cardBackgroundColor="#99FFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeColor="#CCFFFFFF"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <!-- Pulse dot container -->
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="14dp">

                        <View
                            android:id="@+id/viewPulseOuter"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_pulse_lavender"
                            android:alpha="0"/>
                        <View
                            android:id="@+id/viewPulseMiddle"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_pulse_lavender"
                            android:alpha="0"/>
                        <View
                            android:id="@+id/viewStatusDot"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_gravity="center"
                            android:background="@drawable/circle_gray"/>

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thiết bị ESP32"
                            android:textSize="11sp"
                            android:textColor="#636E72"
                            android:fontFamily="@font/montserrat_medium"
                            android:letterSpacing="0.08"/>

                        <TextView
                            android:id="@+id/tvDeviceStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Offline"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#B2BEC3"
                            android:fontFamily="@font/montserrat_bold"/>

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#33A29BFE"
                        android:layout_marginHorizontal="16dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đang trồng"
                            android:textSize="11sp"
                            android:textColor="#636E72"
                            android:fontFamily="@font/montserrat_medium"/>

                        <TextView
                            android:id="@+id/tvPlantName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Chưa chọn"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#A29BFE"
                            android:fontFamily="@font/montserrat_bold"/>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ ALERT BANNER (hiện khi vượt ngưỡng) ══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#80FFE8E2"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="#80FAB1A0"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:id="@+id/iconAlertContainer"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_status_danger_light"
                        android:layout_marginEnd="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_warning"
                            app:tint="#D63031"/>

                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvAlertMessage"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textColor="#D63031"
                        android:textSize="13sp"
                        android:fontFamily="@font/montserrat_medium"
                        android:lineSpacingMultiplier="1.3"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ SENSOR CARDS ROW: Nhiệt độ + Độ ẩm ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- ── Card Nhiệt Độ (glass lavender tint) ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTemperature"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:alpha="0"
                    android:translationY="30dp"
                    app:cardBackgroundColor="#80FFFFFF"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="6dp"
                    app:strokeColor="#CCFFFFFF"
                    app:strokeWidth="1.5dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/labelTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhiệt độ"
                            android:textSize="11sp"
                            android:textColor="#636E72"
                            android:fontFamily="@font/montserrat_medium"
                            android:letterSpacing="0.08"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/lottieTempIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            app:lottie_autoPlay="true"
                            app:lottie_loop="true"
                            app:lottie_rawRes="@raw/temperature"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <!--
                            LiquidGaugeView — Custom View Canvas.
                            Light mode: màu sóng dùng lavender/rose
                            thay vì đỏ tươi của dark mode.
                        -->
                        <com.example.greenhousesystem.ui.widget.LiquidGaugeView
                            android:id="@+id/gaugeTemperature"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            app:gaugeColor="#FAB1A0"
                            app:gaugeWaveColor="#FF7675"
                            app:gaugeMin="0"
                            app:gaugeMax="50"
                            app:layout_constraintTop_toBottomOf="@id/labelTemp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toTopOf="@id/tvTemperature"/>

                        <TextView
                            android:id="@+id/tvTemperature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--°C"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="#2D3436"
                            android:fontFamily="@font/montserrat_bold"
                            app:layout_constraintBottom_toTopOf="@id/tvTempStatus"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/tvTempStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="10sp"
                            android:textColor="#00B894"
                            android:fontFamily="@font/montserrat_medium"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/bg_status_normal_light"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Card Độ Ẩm (glass blue tint) ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHumidity"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:alpha="0"
                    android:translationY="30dp"
                    app:cardBackgroundColor="#80FFFFFF"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="6dp"
                    app:strokeColor="#CCFFFFFF"
                    app:strokeWidth="1.5dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/labelHumid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Độ ẩm"
                            android:textSize="11sp"
                            android:textColor="#636E72"
                            android:fontFamily="@font/montserrat_medium"
                            android:letterSpacing="0.08"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/lottieHumidIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            app:lottie_autoPlay="true"
                            app:lottie_loop="true"
                            app:lottie_rawRes="@raw/water_drop"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <com.example.greenhousesystem.ui.widget.LiquidGaugeView
                            android:id="@+id/gaugeHumidity"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            app:gaugeColor="#74B9FF"
                            app:gaugeWaveColor="#A29BFE"
                            app:gaugeMin="0"
                            app:gaugeMax="100"
                            app:layout_constraintTop_toBottomOf="@id/labelHumid"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toTopOf="@id/tvHumidity"/>

                        <TextView
                            android:id="@+id/tvHumidity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--%"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="#2D3436"
                            android:fontFamily="@font/montserrat_bold"
                            app:layout_constraintBottom_toTopOf="@id/tvHumidityStatus"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/tvHumidityStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="10sp"
                            android:textColor="#00B894"
                            android:fontFamily="@font/montserrat_medium"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/bg_status_normal_light"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══ LED STATUS GLASS CARD ══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                android:translationY="30dp"
                app:cardBackgroundColor="#80FFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeColor="#CCFFFFFF"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <!-- LED Color Orb -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/viewLedGlow"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="3dp"
                        app:strokeColor="#66FFFFFF">

                        <View
                            android:id="@+id/viewLedColor"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#DDE8F5"/>

                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đèn LED RGB"
                            android:textSize="11sp"
                            android:textColor="#636E72"
                            android:fontFamily="@font/montserrat_medium"
                            android:letterSpacing="0.08"/>

                        <TextView
                            android:id="@+id/tvLedMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="-- Chưa có dữ liệu"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#2D3436"
                            android:fontFamily="@font/montserrat_bold"/>

                        <TextView
                            android:id="@+id/tvLedRgb"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="R:0 G:0 B:0"
                            android:textSize="11sp"
                            android:textColor="#B2BEC3"
                            android:fontFamily="@font/montserrat_medium"/>

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchLed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/sunset_lavender"
                        android:trackTint="@color/glass_stroke_lavender"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ TIMESTAMP ══ -->
            <TextView
                android:id="@+id/tvLastUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cập nhật lần cuối: --"
                android:textSize="11sp"
                android:textColor="#B2BEC3"
                android:gravity="center"
                android:alpha="0"
                android:fontFamily="@font/montserrat_medium"
                android:letterSpacing="0.05"/>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>