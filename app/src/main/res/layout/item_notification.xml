<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Icon type -->
        <TextView
            android:id="@+id/tvTypeIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="22sp"
            android:background="@drawable/circle_icon_bg"
            android:text="🌡️" />

        <!-- Nội dung -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cảnh báo nhiệt độ"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Nhiệt độ 37°C vượt ngưỡng an toàn"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Thời gian + trạng thái -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvTimestamp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="14:32 · 25/06/2025"
                    android:textSize="11sp"
                    android:textColor="@color/gray" />

                <TextView
                    android:id="@+id/tvReadStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Chưa đọc"
                    android:textSize="11sp"
                    android:textColor="@color/green_primary"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Indicator chưa đọc (thanh xanh bên trái) -->
    <View
        android:id="@+id/viewUnreadIndicator"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/green_primary" />

</com.google.android.material.card.MaterialCardView>