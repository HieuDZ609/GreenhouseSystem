<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_notification.xml — Màn hình thông báo cảnh báo
    ──────────────────────────────────────────────────────────
    Cấu trúc:
      1. Header stats: Chưa đọc | Tổng cộng | Nút đọc hết
      2. Filter chip group: Tất cả / Chưa đọc / Nhiệt độ / Độ ẩm
      3. ShimmerFrameLayout: placeholder khi đang load
      4. RecyclerView: danh sách thông báo
      5. Empty state: ẩn khi có data, hiện khi rỗng
      6. FAB xóa tất cả (góc dưới phải)

    Lưu ý: AlertWorker.kt là nơi TẠO RA các entry trong
    Firebase notifications/$uid. NotificationViewModel chỉ ĐỌC chúng.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1E12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══ HEADER STATS CARD ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#0F1E12"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#1E3B22"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp">

                <!-- Chưa đọc -->
                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:id="@+id/tvUnreadCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="32sp" android:textStyle="bold"
                        android:textColor="#CCFF00" android:fontFamily="@font/montserrat_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Chưa đọc" android:textSize="11sp" android:textColor="#4A8C52"
                        android:fontFamily="@font/montserrat_medium"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="48dp" android:background="#1E3B22"/>

                <!-- Tổng cộng -->
                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:id="@+id/tvTotalCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="32sp" android:textStyle="bold"
                        android:textColor="#E8F5E9" android:fontFamily="@font/montserrat_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tổng cộng" android:textSize="11sp" android:textColor="#4A8C52"
                        android:fontFamily="@font/montserrat_medium"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="48dp" android:background="#1E3B22"/>

                <!-- Đọc hết button -->
                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:gravity="center" android:id="@+id/btnMarkAllRead"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_bell" app:tint="#CCFF00"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="Đọc hết"
                        android:textSize="11sp" android:textColor="#CCFF00"
                        android:fontFamily="@font/montserrat_medium"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ FILTER CHIP GROUP ══ -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="12dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="6dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Tất cả" android:checked="true"
                    android:textColor="@color/chip_text_color_dark"
                    android:fontFamily="@font/montserrat_medium"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipBackgroundColor="@color/chip_bg_color_dark"
                    app:chipStrokeColor="#2D4A31" app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipUnread"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Chưa đọc"
                    android:textColor="@color/chip_text_color_dark"
                    android:fontFamily="@font/montserrat_medium"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipBackgroundColor="@color/chip_bg_color_dark"
                    app:chipStrokeColor="#2D4A31" app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTemperature"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="🌡️ Nhiệt độ"
                    android:textColor="@color/chip_text_color_dark"
                    android:fontFamily="@font/montserrat_medium"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipBackgroundColor="@color/chip_bg_color_dark"
                    app:chipStrokeColor="#2D4A31" app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHumidity"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="💧 Độ ẩm"
                    android:textColor="@color/chip_text_color_dark"
                    android:fontFamily="@font/montserrat_medium"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipBackgroundColor="@color/chip_bg_color_dark"
                    app:chipStrokeColor="#2D4A31" app:chipStrokeWidth="1dp"/>

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- ══ SHIMMER PLACEHOLDER (hiện khi loading) ══ -->
        <!--
            ShimmerFrameLayout từ Facebook Shimmer library.
            Dependency: implementation("com.facebook.shimmer:shimmer:0.5.0")
            Hiển thị 4 placeholder item giả lập notification card.
        -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:visibility="visible"
            app:shimmer_base_color="#1A2D1E"
            app:shimmer_highlight_color="#2D4A31"
            app:shimmer_auto_start="true">

            <!-- 4 placeholder cards giống item_notification -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <!-- Placeholder 1 -->
                <include layout="@layout/item_shimmer_notification"/>
                <include layout="@layout/item_shimmer_notification"/>
                <include layout="@layout/item_shimmer_notification"/>
                <include layout="@layout/item_shimmer_notification"/>
            </LinearLayout>

        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- ══ EMPTY STATE (ẩn mặc định, hiện khi không có thông báo) ══ -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp"
            android:visibility="gone">

            <!-- Icon rỗng: plant icon mờ -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_plant_placeholder"
                android:alpha="0.3"
                app:tint="#CCFF00"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Chưa có thông báo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#C8E6C9"
                android:fontFamily="@font/montserrat_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Hệ thống sẽ cảnh báo khi\nnhiệt độ hoặc độ ẩm vượt ngưỡng"
                android:textSize="13sp"
                android:textColor="#2D4A31"
                android:fontFamily="@font/montserrat_medium"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"/>

            <!-- Gợi ý: cài đặt ngưỡng -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoToThreshold"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:text="Cài đặt ngưỡng cảnh báo"
                android:textColor="#0F1E12"
                android:fontFamily="@font/montserrat_bold"
                app:backgroundTint="#CCFF00"
                app:cornerRadius="24dp"/>

        </LinearLayout>

        <!-- ══ RECYCLERVIEW ══ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerNotifications"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- ══ FAB XÓA TẤT CẢ ══ -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabDeleteAll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="Xóa tất cả"
        android:textColor="#FFCDD2"
        android:fontFamily="@font/montserrat_bold"
        android:backgroundTint="#8B1A1A"
        app:icon="@drawable/ic_delete"
        app:iconTint="#FFCDD2"
        android:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>