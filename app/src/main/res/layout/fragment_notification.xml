<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sunset_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#80FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeColor="#CCFFFFFF"
            app:strokeWidth="1.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp">

                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:id="@+id/tvUnreadCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="32sp" android:textStyle="bold"
                        android:textColor="#FF7675" android:fontFamily="@font/montserrat_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Chưa đọc" android:textSize="11sp" android:textColor="#636E72"
                        android:fontFamily="@font/montserrat_medium"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="48dp" android:background="#33A29BFE"/>

                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:id="@+id/tvTotalCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="32sp" android:textStyle="bold"
                        android:textColor="#2D3436" android:fontFamily="@font/montserrat_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tổng cộng" android:textSize="11sp" android:textColor="#636E72"
                        android:fontFamily="@font/montserrat_medium"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="48dp" android:background="#33A29BFE"/>

                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:gravity="center" android:id="@+id/btnMarkAllRead"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_bell" app:tint="#A29BFE"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="Đọc hết"
                        android:textSize="11sp" android:textColor="#A29BFE"
                        android:fontFamily="@font/montserrat_medium" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:clipToPadding="false">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Tất cả" android:checked="true"
                    android:textColor="#2D3436"
                    android:fontFamily="@font/montserrat_medium"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipBackgroundColor="#4DFFFFFF"
                    app:chipStrokeColor="#80FFFFFF" app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipUnread"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Chưa đọc"
                    android:textColor="#2D3436"
                    android:fontFamily="@font/montserrat_medium"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipBackgroundColor="#4DFFFFFF"
                    app:chipStrokeColor="#80FFFFFF" app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTemperature"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="🌡️ Nhiệt độ"
                    android:textColor="#2D3436"
                    android:fontFamily="@font/montserrat_medium"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipBackgroundColor="#4DFFFFFF"
                    app:chipStrokeColor="#80FFFFFF" app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHumidity"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="💧 Độ ẩm"
                    android:textColor="#2D3436"
                    android:fontFamily="@font/montserrat_medium"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipBackgroundColor="#4DFFFFFF"
                    app:chipStrokeColor="#80FFFFFF" app:chipStrokeWidth="1dp"/>

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:visibility="visible"
            app:shimmer_base_color="#33A29BFE"
            app:shimmer_highlight_color="#80FFFFFF"
            app:shimmer_auto_start="true">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <include layout="@layout/item_shimmer_notification"/>
                <include layout="@layout/item_shimmer_notification"/>
                <include layout="@layout/item_shimmer_notification"/>
                <include layout="@layout/item_shimmer_notification"/>
            </LinearLayout>

        </com.facebook.shimmer.ShimmerFrameLayout>

        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_plant_placeholder"
                android:alpha="0.4"
                app:tint="#A29BFE"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Chưa có thông báo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2D3436"
                android:fontFamily="@font/montserrat_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Hệ thống sẽ cảnh báo khi\nnhiệt độ hoặc độ ẩm vượt ngưỡng"
                android:textSize="13sp"
                android:textColor="#636E72"
                android:fontFamily="@font/montserrat_medium"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoToThreshold"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:text="Cài đặt ngưỡng cảnh báo"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/montserrat_bold"
                app:backgroundTint="#A29BFE"
                app:cornerRadius="24dp"
                app:elevation="2dp"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerNotifications"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabDeleteAll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="Xóa tất cả"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/montserrat_bold"
        android:backgroundTint="#FF7675"
        app:icon="@drawable/ic_delete"
        app:iconTint="#FFFFFF"
        android:visibility="gone"
        app:elevation="4dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>