<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070E08">

    <!-- Radial glow ở tâm màn hình -->
    <View
        android:id="@+id/viewRadialGlow"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_splash_radial_glow"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"/>

    <!-- Particle decoration -->
    <ImageView
        android:id="@+id/ivParticles"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_hero_particles"
        android:scaleType="centerCrop"
        android:alpha="0.06"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieSplash"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:alpha="0"
        android:scaleX="0.7"
        android:scaleY="0.7"
        app:lottie_autoPlay="true"
        app:lottie_loop="false"
        app:lottie_rawRes="@raw/plant_growing"
        app:lottie_speed="0.8"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSplashAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.38"/>

    <TextView
        android:id="@+id/tvSplashAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="GreenHouse"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="#E8F5E9"
        android:fontFamily="@font/montserrat_bold"
        android:letterSpacing="-0.02"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/lottieSplash"
        app:layout_constraintBottom_toTopOf="@id/tvSplashTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSplashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Make plant perfect ✦"
        android:textSize="14sp"
        android:textColor="#52796F"
        android:fontFamily="@font/montserrat_medium"
        android:letterSpacing="0.1"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/tvSplashAppName"
        app:layout_constraintBottom_toTopOf="@id/splashLoadingBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Loading bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/splashLoadingBar"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:alpha="0"
        android:indeterminate="true"
        app:indicatorColor="#84CC16"
        app:trackColor="#1A2D1E"
        app:trackThickness="3dp"
        app:layout_constraintTop_toBottomOf="@id/tvSplashTagline"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.3"/>

    <!-- Version text -->
    <TextView
        android:id="@+id/tvSplashVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:layout_marginEnd="24dp"
        android:text="v1.0"
        android:textSize="11sp"
        android:textColor="#2D4A31"
        android:fontFamily="@font/montserrat_medium"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Copyright -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="© 2025 GreenHouse System"
        android:textSize="10sp"
        android:textColor="#1A3A1E"
        android:fontFamily="@font/montserrat_medium"
        android:alpha="0.6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>