<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══ CARD BẬT/TẮT LED ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Row: Switch + Preview màu -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Preview màu LED (hình tròn) -->
                    <View
                        android:id="@+id/viewLedPreview"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/circle_gray" />

                    <!-- Tên mode + màu hex -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đèn LED RGB"
                            android:textSize="12sp"
                            android:textColor="@color/gray" />

                        <TextView
                            android:id="@+id/tvCurrentMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="-- Chưa có dữ liệu"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvColorHex"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="R:0 G:0 B:0"
                            android:textSize="12sp"
                            android:textColor="@color/gray" />

                    </LinearLayout>

                    <!-- Switch bật/tắt -->
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchLed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleX="1.2"
                        android:scaleY="1.2"
                        android:thumbTint="@color/green_primary"
                        android:trackTint="@color/green_light" />

                </LinearLayout>

                <!-- Loading bar -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressLed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:indicatorColor="@color/green_primary"
                    app:trackColor="#E8F5E9" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ CARD PRESET MODE ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPreset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chế độ chiếu sáng"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />

                <!-- Row 1: Nảy mầm + Phát triển lá -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <!-- Nảy mầm -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardGermination"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/gray">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌱"
                                android:textSize="28sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Nảy mầm"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/black" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="R:180 G:30 B:120"
                                android:textSize="10sp"
                                android:textColor="@color/gray" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Phát triển lá -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVegetative"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/gray">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🍃"
                                android:textSize="28sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Phát triển lá"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/black" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="R:100 G:20 B:255"
                                android:textSize="10sp"
                                android:textColor="@color/gray" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Row 2: Ra hoa + Đậu quả -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Ra hoa -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardFlowering"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/gray">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌸"
                                android:textSize="28sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Ra hoa"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/black" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="R:255 G:0 B:80"
                                android:textSize="10sp"
                                android:textColor="@color/gray" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Đậu quả -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardFruiting"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/gray">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🍅"
                                android:textSize="28sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Đậu quả"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/black" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="R:255 G:10 B:40"
                                android:textSize="10sp"
                                android:textColor="@color/gray" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Manual mode card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardManual"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/gray">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✋"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Thủ công — Tự chỉnh màu"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ CARD MANUAL SLIDER (chỉ hiện khi chọn MANUAL) ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tùy chỉnh màu sắc"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="16dp" />

                <!-- Preview màu manual -->
                <View
                    android:id="@+id/viewManualPreview"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/rounded_color_bar"
                    android:layout_marginBottom="20dp" />

                <!-- Slider Red -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:text="R"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#E53935" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderRed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="255"
                        android:stepSize="1"
                        app:thumbColor="#E53935"
                        app:trackColorActive="#E53935"
                        app:trackColorInactive="#FFCDD2" />

                    <TextView
                        android:id="@+id/tvRedValue"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="13sp"
                        android:textColor="#E53935"
                        android:gravity="end" />

                </LinearLayout>

                <!-- Slider Green -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:text="G"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#43A047" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderGreen"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="255"
                        android:stepSize="1"
                        app:thumbColor="#43A047"
                        app:trackColorActive="#43A047"
                        app:trackColorInactive="#C8E6C9" />

                    <TextView
                        android:id="@+id/tvGreenValue"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="13sp"
                        android:textColor="#43A047"
                        android:gravity="end" />

                </LinearLayout>

                <!-- Slider Blue -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:text="B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1E88E5" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderBlue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="255"
                        android:stepSize="1"
                        app:thumbColor="#1E88E5"
                        app:trackColorActive="#1E88E5"
                        app:trackColorInactive="#BBDEFB" />

                    <TextView
                        android:id="@+id/tvBlueValue"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="13sp"
                        android:textColor="#1E88E5"
                        android:gravity="end" />

                </LinearLayout>

                <!-- Nút Áp dụng -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApplyManual"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Áp dụng màu"
                    android:textSize="15sp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_led"
                    app:iconGravity="textStart" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>