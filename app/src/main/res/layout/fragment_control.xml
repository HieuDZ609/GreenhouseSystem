<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sunset_gradient"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="40dp"
        android:paddingHorizontal="16dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Điều khiển"
                    android:textSize="12sp"
                    android:textColor="#A29BFE"
                    android:fontFamily="@font/montserrat_medium"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đèn LED RGB"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#2D3436"
                    android:fontFamily="@font/montserrat_bold"/>

            </LinearLayout>

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">

                <View
                    android:id="@+id/viewPowerGlow"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_power_glow_light"
                    android:alpha="0.6"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnPower"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#80FFFFFF"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#CCFFFFFF"
                    app:strokeWidth="1.5dp">

                    <ImageView
                        android:id="@+id/iconPower"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_power"
                        app:tint="#636E72"/>

                </com.google.android.material.card.MaterialCardView>

            </FrameLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLedPreview"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#80FFFFFF"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:strokeColor="#CCFFFFFF"
            app:strokeWidth="1.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/viewLedPreview"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#FFFFFF"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCurrentMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- Chưa có dữ liệu"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#2D3436"
                        android:fontFamily="@font/montserrat_bold"/>

                    <TextView
                        android:id="@+id/tvColorHex"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="R:0  G:0  B:0"
                        android:textSize="12sp"
                        android:textColor="#636E72"
                        android:fontFamily="@font/montserrat_medium"
                        android:letterSpacing="0.05"/>

                </LinearLayout>

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progressLed"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:visibility="gone"
                    app:indicatorColor="#A29BFE"
                    app:trackColor="#33A29BFE"
                    app:indicatorSize="32dp"
                    app:trackThickness="3dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chế độ chiếu sáng"
            android:textSize="13sp"
            android:textColor="#A29BFE"
            android:fontFamily="@font/montserrat_medium"
            android:letterSpacing="0.08"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:clipChildren="false">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGermination"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#66FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#99FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@drawable/bg_mode_orb_germination"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" android:text="Nảy mầm"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="#6C5CE7"
                        android:fontFamily="@font/montserrat_bold" android:gravity="center"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="3dp" android:text="R:180 G:30 B:120"
                        android:textSize="9sp" android:textColor="#636E72" android:fontFamily="@font/montserrat_medium"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVegetative"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#66FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#99FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@drawable/bg_mode_orb_vegetative"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" android:text="Phát triển lá"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="#0984E3"
                        android:fontFamily="@font/montserrat_bold" android:gravity="center"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="3dp" android:text="R:100 G:20 B:255"
                        android:textSize="9sp" android:textColor="#636E72" android:fontFamily="@font/montserrat_medium"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:clipChildren="false">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFlowering"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#66FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#99FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@drawable/bg_mode_orb_flowering"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" android:text="Ra hoa"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="#FF7675"
                        android:fontFamily="@font/montserrat_bold" android:gravity="center"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="3dp" android:text="R:255 G:0 B:80"
                        android:textSize="9sp" android:textColor="#636E72" android:fontFamily="@font/montserrat_medium"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFruiting"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#66FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#99FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@drawable/bg_mode_orb_fruiting"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" android:text="Đậu quả"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="#FAB1A0"
                        android:fontFamily="@font/montserrat_bold" android:gravity="center"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="3dp" android:text="R:255 G:10 B:40"
                        android:textSize="9sp" android:textColor="#636E72" android:fontFamily="@font/montserrat_medium"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardManual"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="20dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#80FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#CCFFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_palette"
                    android:layout_marginEnd="10dp"
                    app:tint="#A29BFE"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thủ công  —  Tự chỉnh màu"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#A29BFE"
                    android:fontFamily="@font/montserrat_bold"
                    android:letterSpacing="0.02"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:alpha="0"
            android:scaleX="0.9"
            android:scaleY="0.9"
            app:cardBackgroundColor="#B3FFFFFF"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tùy chỉnh màu sắc"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#2D3436"
                    android:fontFamily="@font/montserrat_bold"
                    android:layout_marginBottom="20dp"/>

                <com.example.greenhousesystem.ui.widget.ColorOrbitWheelView
                    android:id="@+id/colorOrbitWheel"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="24dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/viewManualPreview"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#FFFFFF"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <TextView android:layout_width="16dp" android:layout_height="wrap_content" android:text="R" android:textSize="13sp" android:textStyle="bold" android:textColor="#FF7675" android:fontFamily="@font/montserrat_bold"/>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderRed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginHorizontal="10dp" android:valueFrom="0" android:valueTo="255" android:stepSize="1"
                        app:thumbColor="#FF7675" app:trackColorActive="#FF7675" app:trackColorInactive="#33FF7675" app:thumbRadius="10dp" app:trackHeight="4dp"/>
                    <TextView android:id="@+id/tvRedValue" android:layout_width="36dp" android:layout_height="wrap_content" android:text="0" android:textSize="12sp" android:textColor="#FF7675" android:fontFamily="@font/montserrat_bold" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <TextView android:layout_width="16dp" android:layout_height="wrap_content" android:text="G" android:textSize="13sp" android:textStyle="bold" android:textColor="#00B894" android:fontFamily="@font/montserrat_bold"/>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderGreen" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginHorizontal="10dp" android:valueFrom="0" android:valueTo="255" android:stepSize="1"
                        app:thumbColor="#00B894" app:trackColorActive="#00B894" app:trackColorInactive="#3300B894" app:thumbRadius="10dp" app:trackHeight="4dp"/>
                    <TextView android:id="@+id/tvGreenValue" android:layout_width="36dp" android:layout_height="wrap_content" android:text="0" android:textSize="12sp" android:textColor="#00B894" android:fontFamily="@font/montserrat_bold" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="20dp">
                    <TextView android:layout_width="16dp" android:layout_height="wrap_content" android:text="B" android:textSize="13sp" android:textStyle="bold" android:textColor="#74B9FF" android:fontFamily="@font/montserrat_bold"/>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderBlue" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginHorizontal="10dp" android:valueFrom="0" android:valueTo="255" android:stepSize="1"
                        app:thumbColor="#74B9FF" app:trackColorActive="#74B9FF" app:trackColorInactive="#3374B9FF" app:thumbRadius="10dp" app:trackHeight="4dp"/>
                    <TextView android:id="@+id/tvBlueValue" android:layout_width="36dp" android:layout_height="wrap_content" android:text="0" android:textSize="12sp" android:textColor="#74B9FF" android:fontFamily="@font/montserrat_bold" android:gravity="end"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApplyManual"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Áp dụng màu"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/montserrat_bold"
                    app:backgroundTint="#A29BFE"
                    app:cornerRadius="16dp"
                    app:rippleColor="#33FFFFFF"
                    app:icon="@drawable/ic_led"
                    app:iconGravity="textStart"
                    app:iconTint="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>