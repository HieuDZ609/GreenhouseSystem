<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_sunset_gradient"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phân tích"
                        android:textSize="12sp"
                        android:textColor="#A29BFE"
                        android:fontFamily="@font/montserrat_medium"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lịch sử dữ liệu"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#2D3436"
                        android:fontFamily="@font/montserrat_bold"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvMockBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Demo data"
                    android:textSize="10sp"
                    android:textColor="#D63031"
                    android:background="@drawable/bg_badge_sunset"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:fontFamily="@font/montserrat_bold"
                    android:visibility="gone"/>

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#66FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#CCFFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="6dp">

                    <TextView
                        android:id="@+id/btnFilterToday"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Hôm nay"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#6C5CE7"
                        android:fontFamily="@font/montserrat_bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_filter_active_light"/>

                    <TextView
                        android:id="@+id/btnFilterWeek"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="7 ngày"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#636E72"
                        android:fontFamily="@font/montserrat_medium"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/btnFilterMonth"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="30 ngày"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#636E72"
                        android:fontFamily="@font/montserrat_medium"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#80FFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeColor="#CCFFFFFF"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="🌡️ Nhiệt độ (°C)"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#2D3436"
                            android:fontFamily="@font/montserrat_bold"/>

                        <TextView
                            android:id="@+id/tvTempThreshold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngưỡng: --°C ~ --°C"
                            android:textSize="10sp"
                            android:textColor="#B2BEC3"
                            android:fontFamily="@font/montserrat_medium"/>

                    </LinearLayout>

                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:id="@+id/shimmerTemp"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:visibility="visible"
                        app:shimmer_base_color="#33A29BFE"
                        app:shimmer_highlight_color="#80FFFFFF"
                        app:shimmer_auto_start="true">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:background="@drawable/bg_shimmer_rect_light"/>

                    </com.facebook.shimmer.ShimmerFrameLayout>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartTemperature"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:visibility="invisible"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_stats_row_light"
                        android:padding="12dp">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Thấp nhất" android:textSize="10sp" android:textColor="#636E72"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvTempMin" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--°C"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#74B9FF" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="36dp" android:background="#33A29BFE"/>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Trung bình" android:textSize="10sp" android:textColor="#636E72"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvTempAvg" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--°C"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#A29BFE" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="36dp" android:background="#33A29BFE"/>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Cao nhất" android:textSize="10sp" android:textColor="#636E72"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvTempMax" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--°C"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#FF7675" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#80FFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeColor="#CCFFFFFF"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="💧 Độ ẩm (%)"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#2D3436"
                            android:fontFamily="@font/montserrat_bold"/>

                        <TextView
                            android:id="@+id/tvHumidThreshold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngưỡng: --% ~ --%"
                            android:textSize="10sp"
                            android:textColor="#B2BEC3"
                            android:fontFamily="@font/montserrat_medium"/>

                    </LinearLayout>

                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:id="@+id/shimmerHumid"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:visibility="visible"
                        app:shimmer_base_color="#3374B9FF"
                        app:shimmer_highlight_color="#80FFFFFF"
                        app:shimmer_auto_start="true">
                        <View android:layout_width="match_parent" android:layout_height="200dp"
                            android:background="@drawable/bg_shimmer_rect_light"/>
                    </com.facebook.shimmer.ShimmerFrameLayout>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartHumidity"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:visibility="invisible"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_stats_row_light"
                        android:padding="12dp">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Thấp nhất" android:textSize="10sp" android:textColor="#636E72"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvHumidMin" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--%"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#74B9FF" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="36dp" android:background="#33A29BFE"/>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Trung bình" android:textSize="10sp" android:textColor="#636E72"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvHumidAvg" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--%"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#A29BFE" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="36dp" android:background="#33A29BFE"/>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Cao nhất" android:textSize="10sp" android:textColor="#636E72"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvHumidMax" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--%"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#FF7675" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>