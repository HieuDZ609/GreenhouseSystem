<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_chart_new.xml — Màn hình biểu đồ "Eco-Digital Dark"
    Cấu trúc:
      • Filter Strip (Hôm nay / 7 ngày / 30 ngày) với lime glow
      • Shimmer placeholder khi loading
      • Card nhiệt độ: chart + stats min/avg/max
      • Card độ ẩm:    chart + stats min/avg/max
-->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_eco_dark"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- ══ HEADER ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phân tích"
                        android:textSize="12sp"
                        android:textColor="#4A8C52"
                        android:fontFamily="@font/montserrat_medium"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lịch sử dữ liệu"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#E8F5E9"
                        android:fontFamily="@font/montserrat_bold"/>

                </LinearLayout>

                <!-- Badge "Demo data" khi không có data thật -->
                <TextView
                    android:id="@+id/tvMockBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Demo data"
                    android:textSize="10sp"
                    android:textColor="#0A1A0A"
                    android:background="@drawable/bg_badge_amber"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:fontFamily="@font/montserrat_bold"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- ══ FILTER STRIP ══
                 3 nút chọn khoảng thời gian.
                 Nút active: background lime mờ + text lime sáng + scale 1.05.
                 Nút inactive: transparent + text mờ.
                 Được wrap trong card glassmorphic.
            -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#0F1E12"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E3B22"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="6dp">

                    <TextView
                        android:id="@+id/btnFilterToday"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Hôm nay"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#84CC16"
                        android:fontFamily="@font/montserrat_bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_filter_active"/>

                    <TextView
                        android:id="@+id/btnFilterWeek"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="7 ngày"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#4A6A4E"
                        android:fontFamily="@font/montserrat_bold"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/btnFilterMonth"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="30 ngày"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#4A6A4E"
                        android:fontFamily="@font/montserrat_bold"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ CARD NHIỆT ĐỘ ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#0F1E12"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E3B22"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Tiêu đề + ngưỡng -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="🌡️ Nhiệt độ (°C)"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#C8E6C9"
                            android:fontFamily="@font/montserrat_bold"/>

                        <TextView
                            android:id="@+id/tvTempThreshold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngưỡng: --°C ~ --°C"
                            android:textSize="10sp"
                            android:textColor="#3A6A3E"
                            android:fontFamily="@font/montserrat_medium"/>

                    </LinearLayout>

                    <!-- Shimmer placeholder khi loading -->
                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:id="@+id/shimmerTemp"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:visibility="visible"
                        app:shimmer_base_color="#1A2D1E"
                        app:shimmer_highlight_color="#2D4A31"
                        app:shimmer_auto_start="true">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:background="@drawable/bg_shimmer_rect"/>

                    </com.facebook.shimmer.ShimmerFrameLayout>

                    <!-- Chart thật (ẩn khi loading) -->
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartTemperature"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:visibility="invisible"/>

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_stats_row"
                        android:padding="12dp">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Thấp nhất" android:textSize="10sp" android:textColor="#4A6A4E"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvTempMin" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--°C"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#64B5F6" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="36dp" android:background="#1A3B22"/>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Trung bình" android:textSize="10sp" android:textColor="#4A6A4E"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvTempAvg" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--°C"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#84CC16" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="36dp" android:background="#1A3B22"/>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Cao nhất" android:textSize="10sp" android:textColor="#4A6A4E"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvTempMax" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--°C"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#EF5350" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ CARD ĐỘ ẨM ══ (cấu trúc tương tự card nhiệt độ) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#0D1A2A"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1A3550"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="💧 Độ ẩm (%)"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#BBDEFB"
                            android:fontFamily="@font/montserrat_bold"/>

                        <TextView
                            android:id="@+id/tvHumidThreshold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngưỡng: --% ~ --%"
                            android:textSize="10sp"
                            android:textColor="#1E4A70"
                            android:fontFamily="@font/montserrat_medium"/>

                    </LinearLayout>

                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:id="@+id/shimmerHumid"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:visibility="visible"
                        app:shimmer_base_color="#0D2040"
                        app:shimmer_highlight_color="#1A3560"
                        app:shimmer_auto_start="true">
                        <View android:layout_width="match_parent" android:layout_height="200dp"
                            android:background="@drawable/bg_shimmer_rect"/>
                    </com.facebook.shimmer.ShimmerFrameLayout>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartHumidity"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:visibility="invisible"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_stats_row_blue"
                        android:padding="12dp">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Thấp nhất" android:textSize="10sp" android:textColor="#1A4A70"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvHumidMin" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--%"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#64B5F6" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="36dp" android:background="#1A3560"/>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Trung bình" android:textSize="10sp" android:textColor="#1A4A70"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvHumidAvg" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--%"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#42A5F5" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="36dp" android:background="#1A3560"/>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Cao nhất" android:textSize="10sp" android:textColor="#1A4A70"
                                android:fontFamily="@font/montserrat_medium"/>
                            <TextView android:id="@+id/tvHumidMax" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--%"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#EF5350" android:fontFamily="@font/montserrat_bold"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>