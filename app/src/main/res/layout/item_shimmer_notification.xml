<?xml version="1.0" encoding="utf-8"?>
<!--
    item_shimmer_notification.xml — Skeleton placeholder cho loading state
    ────────────────────────────────────────────────────────────────────────
    Cấu trúc GIỐNG item_notification.xml nhưng thay bằng gray boxes.
    Được bọc trong ShimmerFrameLayout → các box sẽ có hiệu ứng sóng sáng.

    Shimmer library: com.facebook.shimmer:shimmer:0.5.0
    Dùng: ShimmerFrameLayout.startShimmer() / stopShimmer()

    Các thành phần giả lập:
    • Vòng tròn bên trái (48dp) = icon type
    • 3 box chữ nhật bên phải = title + message + timestamp
    • Box nhỏ góc phải = sensor value
    • Viền trái 4dp = type indicator
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="#0F1E12"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#1E3B22"
    app:strokeWidth="1dp">

    <!-- Viền trái indicator (skeleton) -->
    <View
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="#1A3B22"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:paddingStart="20dp"
        android:gravity="center_vertical">

        <!-- ── ICON CIRCLE SKELETON ── -->
        <View
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_shimmer_circle"/>

        <!-- ── TEXT CONTENT SKELETONS ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title skeleton: rộng 70% -->
            <View
                android:layout_width="0dp"
                android:layout_height="14dp"
                android:layout_weight="0"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_shimmer_rect"
                android:minWidth="180dp"/>

            <!-- Message skeleton: 2 dòng -->
            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/bg_shimmer_rect"/>

            <View
                android:layout_width="120dp"
                android:layout_height="10dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_shimmer_rect"/>

            <!-- Timestamp + badge skeleton -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Timestamp -->
                <View
                    android:layout_width="80dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_shimmer_rect"/>

                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1"/>

                <!-- Badge -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_shimmer_rect"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ── SENSOR VALUE SKELETON ── -->
        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp">

            <View
                android:layout_width="44dp"
                android:layout_height="20dp"
                android:background="@drawable/bg_shimmer_rect"
                android:layout_marginBottom="4dp"/>

            <View
                android:layout_width="32dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_shimmer_rect"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>