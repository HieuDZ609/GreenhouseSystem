<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:orientation="vertical"
    android:background="@drawable/bg_sunset_gradient"
    android:padding="24dp"
    android:gravity="bottom">

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_power_glow_light"
        android:alpha="0.4"
        android:layout_gravity="end"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-40dp"/>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivHeaderAvatar"
        android:layout_width="72dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_person"
        android:background="#E8E6FF"
        app:shapeAppearanceOverlay="@style/CircleImageView"
        app:strokeColor="#A29BFE"
        app:strokeWidth="2.5dp"
        android:padding="4dp"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="-120dp"/>

    <TextView
        android:id="@+id/tvHeaderName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên người dùng"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2D3436"
        android:fontFamily="@font/montserrat_bold"/>

    <TextView
        android:id="@+id/tvHeaderEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="email@example.com"
        android:textSize="12sp"
        android:textColor="#636E72"
        android:fontFamily="@font/montserrat_medium"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="0dp"
        android:layout_paddingBottom="10dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#4DFFFFFF"
        android:layout_marginBottom="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_plant_placeholder"
            android:layout_marginEnd="6dp"
            app:tint="#A29BFE"/>

        <TextView
            android:id="@+id/tvGardenName"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Vườn của tôi"
            android:textSize="12sp"
            android:textColor="#A29BFE"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat_bold"
            android:letterSpacing="0.02"/>

        <TextView
            android:id="@+id/tvHeaderVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.0"
            android:textSize="10sp"
            android:textColor="#B2BEC3"
            android:fontFamily="@font/montserrat_medium"/>

    </LinearLayout>
</LinearLayout>