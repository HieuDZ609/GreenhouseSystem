<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Lớp kính chính: trắng 50% -->
    <solid android:color="#80FFFFFF"/>

    <!-- Viền kính bắt sáng: trắng 80% (sáng hơn fill) -->
    <stroke
        android:width="1.5dp"
        android:color="#CCFFFFFF"/>

    <!-- Bo góc mềm mại: 24dp -->
    <corners android:radius="24dp"/>

    <!-- Padding nội dung -->
    <padding
        android:left="20dp"
        android:top="20dp"
        android:right="20dp"
        android:bottom="20dp"/>

</shape>