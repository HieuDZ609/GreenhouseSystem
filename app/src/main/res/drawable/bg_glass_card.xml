<?xml version="1.0" encoding="utf-8"?>
<!-- ══════════════════════════════════════════════════════════════
     bg_glass_card.xml
     Glassmorphic card background: nền tối bán trong suốt,
     viền lime mờ (#33CCFF00), bo góc 24dp.
     Dùng cho tất cả card trong Dark Mode theme.
     ══════════════════════════════════════════════════════════════ -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Nền kính tối: trắng với alpha ~10% -->
    <solid android:color="#1AFFFFFF"/>
    <!-- Viền lime rất mờ: CCFF00 với alpha ~20% -->
    <stroke
        android:width="1dp"
        android:color="#33CCFF00"/>
    <corners android:radius="24dp"/>
</shape>