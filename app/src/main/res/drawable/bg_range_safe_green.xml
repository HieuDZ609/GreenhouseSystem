<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_range_safe_green.xml
    Thanh "Vùng an toàn" màu lime cho dải nhiệt độ.
    Gradient từ lime nhạt → lime đậm → lime nhạt tạo cảm giác "phát sáng".
    Width được set động trong ThresholdFragment dựa trên (max - min) / range.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="#80CCFF00"
        android:centerColor="#CCFF00"
        android:endColor="#80CCFF00"/>
    <corners android:radius="5dp"/>
</shape>