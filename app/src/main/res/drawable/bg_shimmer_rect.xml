<?xml version="1.0" encoding="utf-8"?>
<!-- ══════════════════════════════════════════════════════════════
     bg_shimmer_rect.xml
     Gradient placeholder khi đang loading data (Shimmer effect).
     Màu: dark gray → lighter gray → dark gray (sweep effect).
     ══════════════════════════════════════════════════════════════ -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="#1A1A1A"
        android:centerColor="#333333"
        android:endColor="#1A1A1A"/>
    <corners android:radius="12dp"/>
</shape>