<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_range_track_dark.xml
    Track nền tối cho RangeSlider (nhiệt độ).
    Màu xanh lá rất tối để track không bị lẫn vào background.
    Bo góc 5dp để hòa hợp với thumb tròn của slider.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#1A3B22"/>
    <corners android:radius="5dp"/>
</shape>