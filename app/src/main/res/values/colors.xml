    <!--
    colors.xml — Soft Sunset × Glassmorphism Light Mode
    ══════════════════════════════════════════════════════════
    Quy ước mã màu 8 ký tự: #AARRGGBB
      AA = Alpha channel (hex):
        FF = 100% opacity    (hoàn toàn đục)
        CC = 80% opacity     (viền kính — bắt sáng)
        99 = 60% opacity     (card kính đậm)
        80 = 50% opacity     (card kính trung bình)
        66 = 40% opacity     (card kính mỏng)
        4D = 30% opacity     (overlay siêu mỏng)
        33 = 20% opacity     (hint / divider)
        1A = 10% opacity     (background tint nhẹ)

    Glassmorphism "thật":
      • Nền card: #66FFFFFF (trắng 40%) → trông như kính mờ
      • Viền card: #CCFFFFFF (trắng 80%) → cạnh kính bắt sáng
      • Shadow: màu accent mờ → tạo depth tự nhiên
-->

