<?xml version="1.0" encoding="utf-8"?>
<!--
    themes.xml (res/values/themes.xml — Light Mode)
    ══════════════════════════════════════════════════════════
    Cấu trúc theme hỗ trợ cả Dark Mode và Light Mode:

    Theme.GreenhouseSystem
    ├── Kế thừa từ Theme.Material3.DayNight.NoActionBar
    ├── Tự chọn Light/Dark dựa trên system setting
    │
    Theme.GreenhouseSystem.Light   ← File này (res/values/)
    └── Override colorPrimary, colorSurface... sang Sunset palette

    Theme.GreenhouseSystem.Dark    ← Trong res/values-night/
    └── Override sang Eco-Digital Dark palette (#0F1E12, #CCFF00)

    Để áp dụng toggle thủ công: AppCompatDelegate.setDefaultNightMode()
    (xem ThemeToggleHelper.kt bên dưới)
-->
<resources>

    <!-- ══ THEME CHÍNH (kế thừa DayNight — tự chọn light/dark) ══ -->
    <!--
        Đây là theme DayNight — Android tự chọn Light/Dark
        dựa trên cài đặt hệ thống hoặc AppCompatDelegate.
        Không cần define cả 2 theme; chỉ cần override đúng màu
        trong res/values/ (light) và res/values-night/ (dark).
    -->
    <style name="Theme.GreenhouseSystem"
        parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Material 3 Color Roles — Light Mode defaults -->
        <item name="colorPrimary">@color/sunset_lavender</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">#E8E6FF</item>
        <item name="colorOnPrimaryContainer">@color/text_accent</item>

        <item name="colorSecondary">@color/sunset_pink</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSecondaryContainer">#FFE8E2</item>
        <item name="colorOnSecondaryContainer">#4A2018</item>

        <item name="colorTertiary">@color/sunset_gold</item>
        <item name="colorOnTertiary">@color/text_primary_light</item>
        <item name="colorTertiaryContainer">#FFF8D6</item>
        <item name="colorOnTertiaryContainer">#3D2E00</item>

        <!-- Surface và Background -->
        <item name="colorSurface">@color/sunset_cream</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        <item name="colorSurfaceVariant">#F0EEF8</item>  <!-- Lavender tint nhẹ -->
        <item name="colorOnSurfaceVariant">@color/text_secondary_light</item>
        <item name="android:colorBackground">@color/sunset_cream</item>
        <item name="colorOnBackground">@color/text_primary_light</item>

        <!-- Outline và Divider -->
        <item name="colorOutline">@color/glass_stroke_lavender</item>
        <item name="colorOutlineVariant">@color/glass_stroke_soft</item>

        <!-- Error -->
        <item name="colorError">@color/sunset_rose</item>
        <item name="colorOnError">#FFFFFF</item>

        <!-- Status bar & Navigation bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bottom_nav_bg_light</item>
        <item name="android:windowLightStatusBar">true</item>  <!-- Icons tối trên status bar sáng -->
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Window background: gradient được set qua drawable -->
        <item name="android:windowBackground">@drawable/bg_sunset_gradient</item>

        <!-- Ripple effect nhẹ nhàng -->
        <item name="colorControlHighlight">@color/ripple_light</item>

        <!-- Shape defaults — bo góc nhiều hơn cho vibe organic -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall.Sunset</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium.Sunset</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge.Sunset</item>

        <!-- Typography -->
        <!-- <item name="fontFamily">@font/nunito</item> -->

        <!-- BottomNavigationView -->
        <item name="bottomNavigationStyle">@style/Widget.Sunset.BottomNavigation</item>
    </style>

    <!-- ══ SPLASH THEME ══════════════════════════════════════════ -->
    <style name="Theme.GreenhouseSystem.Splash" parent="Theme.GreenhouseSystem">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@drawable/bg_sunset_gradient</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- ══ DIALOG THEME (Light Mode) ════════════════════════════ -->
    <style name="SunsetDialogStyle"
        parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/glass_thick</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        <item name="colorPrimary">@color/sunset_lavender</item>
        <item name="android:backgroundDimAmount">0.35</item>
        <!-- Background trong suốt để card XML của dialog hiện ra -->
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!-- ══ SHAPE STYLES ══════════════════════════════════════════ -->
    <!-- Small: 16dp — Chip, Button nhỏ -->
    <style name="ShapeSmall.Sunset" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Medium: 24dp — Card thông thường, Sheet -->
    <style name="ShapeMedium.Sunset" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Large: 32dp — Bottom sheet, Full panel -->
    <style name="ShapeLarge.Sunset" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">32dp</item>
    </style>

    <!-- Circle: 50% — Avatar, FAB tròn -->
    <style name="CircleShape.Sunset" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ══ TEXTINPUTLAYOUT — LIGHT ══════════════════════════════ -->
    <style name="SunsetTextInput"
        parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/sunset_lavender</item>
        <item name="boxBackgroundColor">#80FFFFFF</item>     <!-- Glass medium fill -->
        <item name="hintTextColor">@color/text_secondary_light</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="android:textColorHint">@color/text_hint_light</item>
    </style>

    <!-- ══ BUTTON — LIGHT ════════════════════════════════════════ -->
    <style name="SunsetButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/sunset_lavender</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="cornerRadius">24dp</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>

    <style name="SunsetButton.Outlined"
        parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/sunset_lavender</item>
        <item name="android:textColor">@color/sunset_lavender</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <!-- ══ CHIP — LIGHT ══════════════════════════════════════════ -->
    <style name="SunsetChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_bg_light</item>
        <item name="android:textColor">@color/chip_text_light</item>
        <item name="chipStrokeColor">@color/glass_stroke_gold</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <!-- ══ BOTTOM NAVIGATION — LIGHT ════════════════════════════ -->
    <style name="Widget.Sunset.BottomNavigation"
        parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@drawable/bg_bottom_nav_glass</item>
        <item name="itemIconTint">@color/bottom_nav_icon_color_light</item>
        <item name="itemTextColor">@color/bottom_nav_icon_color_light</item>
        <item name="elevation">0dp</item>  <!-- Elevation = 0, dùng backdrop blur thay -->
    </style>

</resources>